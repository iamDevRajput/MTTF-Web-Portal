PORT=8000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/MTTF
JWT_SECRET=replace-with-a-long-random-secret

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# ─── Razorpay Payment Gateway ─────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/website-app-settings/api-keys
RAZORPAY_KEY_ID=rzp_test_replace_with_your_key_id
RAZORPAY_KEY_SECRET=replace_with_your_key_secret

# Webhook secret — set this in Razorpay Dashboard > Webhooks > Secret
RAZORPAY_WEBHOOK_SECRET=replace_with_your_webhook_secret

# Environment: "test" for sandbox, "production" for live
RAZORPAY_ENV=test

# Set to "true" to skip Razorpay API calls for local UI testing
RAZORPAY_MOCK_MODE=false

# Public URL of your backend (used for webhook URL construction)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Optional: email delivery for successful verified memberships
EMAIL_USER=your-smtp-or-gmail-user
EMAIL_PASS=your-smtp-or-gmail-app-password
EMAIL_FROM=MTTF <no-reply@example.com>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
